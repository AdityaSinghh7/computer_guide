{
  "name": "computer_guide",
  "version": "1.0.0",
  "private": true,
  "description": "Mastra project scaffold for computer_guide",
  "scripts": {
    "dev": "./scripts/with-dotenv.sh mastra dev",
    "build": "./scripts/with-dotenv.sh mastra build",
    "typecheck": "tsc --noEmit",
    "chat:agent": "./scripts/with-dotenv.sh node --import tsx src/scripts/chatMainAgent.ts",
    "chat:agent:reset-memory": "./scripts/with-dotenv.sh node --import tsx src/scripts/resetMainAgentMemory.ts",
    "desktop-server:build": "./scripts/with-dotenv.sh env PATH=\"$HOME/.swiftly/bin:$PATH\" \"$HOME/.swiftly/bin/swift\" build --package-path desktop-server",
    "desktop-server:install-app": "./scripts/with-dotenv.sh ./scripts/install-desktop-server-app.sh",
    "desktop-server:start": "./desktop-server/run-from-repo-root.sh",
    "desktop-server:start:dev": "./desktop-server/run-dev-from-repo-root.sh",
    "desktop-server:status": "./scripts/with-dotenv.sh ./scripts/desktop-server-status.sh",
    "desktop-server:stop": "./scripts/with-dotenv.sh ./scripts/desktop-server-stop.sh",
    "e2e:desktop-agent": "./scripts/with-dotenv.sh node --import tsx src/evals/desktopAgentE2E.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdityaSinghh7/computer_guide.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/AdityaSinghh7/computer_guide/issues"
  },
  "homepage": "https://github.com/AdityaSinghh7/computer_guide#readme",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@mastra/core": "^1.10.0",
    "@mastra/libsql": "^1.6.4",
    "@mastra/memory": "^1.6.1",
    "mastra": "^1.3.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
